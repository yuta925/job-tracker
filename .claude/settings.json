{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(supabase db reset:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase migration:*)",
      "Bash(npm run test:*)",
      "Bash(npm run build:*)"
    ]
  },
  "env": {
    "TZ": "Asia/Tokyo"
  }
}
